{
  "name": "axiom-stem",
  "version": "1.0.0",
  "private": false,
  "description": "AXIOM — a verifiable STEM tutor that computes first and uses OpenAI only to explain cited results",
  "license": "MIT",
  "author": "RADHIKATMOSPHERE (https://github.com/radhikatmosphere)",
  "repository": {
    "type": "git",
    "url": "https://github.com/radhikatmosphere/axiom-stem.git"
  },
  "keywords": [
    "stem-education",
    "ai-tutor",
    "openai",
    "nextjs",
    "hackathon",
    "genetics",
    "combinatorics",
    "edtech",
    "verification"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app components lib tests bench types --max-warnings=0",
    "test": "node tests/decomposers.test.mjs && node tests/narrative-verifier.test.mjs && node tests/chat.test.mjs && node tests/chat-router.test.mjs",
    "benchmark": "node bench/run-benchmark.mjs",
    "eval": "node bench/run-eval.mjs",
    "submission:zip": "bash scripts/build-submission-zip.sh"
  },
  "dependencies": {
    "@azure/ai-projects": "^2.3.1",
    "@azure/identity": "^4.13.1",
    "lucide-react": "^0.469.0",
    "next": "15.4.11",
    "openai": "^6.48.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.28.1",
    "eslint": "^8",
    "eslint-config-next": "15.4.11",
    "playwright": "^1.61.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
