# Layer 2 — Narrative Adapter (primary: SuperGrok / xAI Grok)
XAI_API_KEY=
XAI_MODEL=grok-4.3

# Layer 2 — Fallback via RadhikaChain agent-core
AGENT_CORE_URL=https://agent-core.radhikachain.xyz

# Splunk HEC — index axiom (Dashboard Studio)
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
SPLUNK_INDEX=axiom
SPLUNK_SOURCETYPE=_json
