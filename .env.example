# SPLUNK_PROXY_URL=https://radhikachain.xyz/api/splunk/hec
# SPLUNK_SENSOR_KEY=

# RadhikaChain auth + wallet / Bhakti API
NEXT_PUBLIC_AUTH_API_URL=https://radhikachain.xyz
