# Optional: without these, AXIOM stays fully usable in deterministic fallback mode.
# Keep this file as a template only; put real values in .env.local.
OPENAI_API_KEY=
# Supply a valid model ID available to your OpenAI account.
OPENAI_MODEL=
# Optional: Azure AI Foundry agent reference. When all three are set, the
# narrative layer can optionally call an Azure-hosted agent; otherwise AXIOM
# falls back to the deterministic narrative. Never use NEXT_PUBLIC_ for these.
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_AGENT_NAME=
AZURE_AI_AGENT_VERSION=

